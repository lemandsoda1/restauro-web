# ── Restauro web — environment variables ────────────────────────────────────
# On Vercel, POSTGRES_URL and BLOB_READ_WRITE_TOKEN are added automatically
# when you connect a Postgres database and a Blob store to the project.
# Copy this file to server/.env for local development.

# Vercel Postgres / Neon connection string
POSTGRES_URL=

# Vercel Blob read/write token (for image uploads)
BLOB_READ_WRITE_TOKEN=

# Secret used to sign login tokens — use a long random string in production
JWT_SECRET=change-me-to-a-long-random-string

# Initial admin account (seeded on first run if it doesn't exist)
ADMIN_EMAIL=admin@restauro.local
ADMIN_PASSWORD=change-me
